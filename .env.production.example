NODE_ENV=production
PORT=3000
APP_BASE_URL=https://monitoring.example.com
SESSION_SECRET=change-me-please
SESSION_NAME=monitoring.sid
LOG_LEVEL=info
TIMEZONE=Asia/Jakarta

DATABASE_URL=postgresql://monitoring:monitoring@db:5432/monitoring?schema=public
REDIS_URL=redis://redis:6379
STORAGE_PATH=/storage

FETCH_TIMEOUT_MS=8000
PLAYWRIGHT_TIMEOUT_MS=15000
MAX_BODY_BYTES=1000000
MAX_HTML_CHARS=500000
MAX_REDIRECTS=5
CHECK_CONCURRENCY=5
DEEP_CHECK_CONCURRENCY=3
PER_DOMAIN_DELAY_MS=1000
MIN_TEXT_LENGTH_FOR_LIGHT=120
DEEP_CHECK_ON_FIRST_RUN=true
EVIDENCE_JPEG_QUALITY=65
EVIDENCE_MAX_WIDTH=1280
INCIDENT_EVIDENCE_RETENTION_COUNT=2
CHECK_RESULT_RETENTION_COUNT=60
CHECK_RESULT_PRUNE_INTERVAL_MIN=10
DETAILED_EXTRACTED_TEXT_MAX_CHARS=3000
CLOSED_INCIDENT_RETENTION_DAYS=7
RETENTION_MAINTENANCE_INTERVAL_MIN=60
NEGATIVE_SCORE_THRESHOLD=60
PHASH_DELTA_THRESHOLD=12
CLEAN_CHECKS_TO_CLOSE=3
NOTIFY_COOLDOWN_MIN=10

ALLOW_OPERATOR_MANAGE_TARGETS=false
ENABLE_ACK_LINKS=true
ACK_TOKEN_TTL_MIN=60
ENABLE_OCR=false
TESSERACT_LANG=eng
ENABLE_IMAGE_DETECTION=true
IMAGE_SKIN_TONE_THRESHOLD=12
IMAGE_SKIN_TONE_MAX_SCORE=60
IMAGE_SAMPLE_SIZE=120
IMAGE_SAMPLE_STRIDE=2
ENABLE_IMAGE_CLASSIFIER=true
IMAGE_CLASSIFIER_MODEL=MobileNetV2
IMAGE_CLASSIFIER_MIN_CONFIDENCE=0.7
IMAGE_CLASSIFIER_INPUT_SIZE=224

LOGIN_RATE_LIMIT_WINDOW_MIN=15
LOGIN_RATE_LIMIT_MAX=5

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
